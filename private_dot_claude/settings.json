{
  "autoCompactEnabled": true,
  "autoUpdates": false,
  "disableBypassPermissionsMode": "disable",
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [
  ],
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard-git-push.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git amend:*)",
      "Bash(git bisect:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git grep:*)",
      "Bash(git log:*)",
      "Bash(git ls-files:*)",
      "Bash(git merge --ff-only:*)",
      "Bash(git pull:*)",
      "Bash(git rebase:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(kubectl explain:*)",
      "Bash(kubectl --dry-run=client:*)",
      "Bash(markdownlint-cli2:*)",
      "Bash(pre-commit install:*)",
      "Bash(pre-commit run:*)",
      "Bash(shellcheck:*)",
      "Bash(yamllint:*)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Edit",
      "MultiEdit",
      "WebFetch",
      "WebSearch",
      "mcp__context7"
    ],
    "deny": [
      "Read(~/.env*)",
      "Read(~/.secrets*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "padding": 0,
    "refreshInterval": 15
  },
  "theme": "dark",
  "tui": "fullscreen"
}
